{
  "name": "kamix/gestfinance",
  "description": "Système de gestion des besoins financiers",
  "type": "project",
  "require": {
    "php": ">=8.3",
    "dompdf/dompdf": "^3.0",
    "vlucas/phpdotenv": "^5.6",
    "ext-pdo": "*"
  },
  "autoload": {
    "psr-4": {
      "App\\": "app/"
    }
  },
  "config": {
    "optimize-autoloader": true,
    "allow-plugins": {
      "php-http/discovery": true
    }
  }
}
